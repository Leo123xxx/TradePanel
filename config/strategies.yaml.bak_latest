dual_ema_fractal:
  name: Dual EMA Fractal Breaker
  category: Trend Following
  status: implemented
  regime:
  - TRENDING
  enabled: true
  tier: TIER_1
  pairs:
  - EURUSD
  - GBPUSD
  - XAUUSD
  - GBPJPY
  - AUDUSD
  - USDCAD
  - USOIL
  timeframes:
  - M5
  - M15
  - M30
  - H1
  - H2
  - H4
  - H12
  - D1
  parameters:
    ema_fast: 50
    ema_slow: 100
    adx_min: 28
    rsi_period: 14
    rsi_long_min: 55
    rsi_short_max: 42
    atr_period: 14
    tp_atr_mult: 3.5
    sl_atr_mult: 1.0
    use_breakeven: true
    breakeven_trigger_mult: 1.5
    use_multi_tf_confirmation: true
    confirm_timeframe: H4
    vol_threshold_mult: 1.5
  pair_overrides:
    XAUUSD:
      adx_min: 28
      tp_atr_mult: 4.0
      sl_atr_mult: 0.8
    GBPUSD:
      confirm_timeframe: D1
    GBPJPY:
      adx_min: 28
      tp_atr_mult: 4.0
    AUDUSD:
      adx_min: 33
      vol_threshold_mult: 1.6
    USDCAD:
      adx_min: 33
      vol_threshold_mult: 1.6
    USOIL:
      adx_min: 33
      sl_atr_mult: 0.7
      tp_atr_mult: 3.5
  mode: trade
  lot_size: 0.3
