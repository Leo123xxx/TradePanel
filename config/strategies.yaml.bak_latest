ma_crossover:
  name: Moving Average Crossover
  category: Trend Following
  status: implemented
  regime:
  - TRENDING
  - ANY
  enabled: true
  tier: TIER_3
  pairs:
  - EURUSD
  - AUDUSD
  - GBPJPY
  timeframes:
  - M5
  - M15
  - M30
  - H1
  - H2
  - H4
  - H12
  - D1
  parameters:
    fast_period: 10
    slow_period: 21
    ma_type: EMA
    atr_period: 14
    adx_filter: 28
    tp_atr_mult: 3.5
    sl_atr_mult: 0.8
    use_multi_tf_confirmation: true
    confirm_timeframe: H4
    vol_threshold_mult: 1.3
  pair_overrides:
    USDJPY:
      fast_period: 10
      slow_period: 25
      adx_filter: 30
      confirm_timeframe: D1
    GBPUSD:
      adx_filter: 28
      sl_atr_mult: 1.1
    GBPUSD:H4:
      allow_long: false
    GBPUSD:H1:
      allow_short: false
    EURUSD:
      adx_filter: 28
      confirm_timeframe: D1
      vol_threshold_mult: 1.5
      adx_min: 28
      tp_atr_mult: 4.0
    GBPJPY:
      adx_filter: 28
      confirm_timeframe: D1
      adx_min: 28
      tp_atr_mult: 4.0
  mode: trade
  lot_size: 0.5
